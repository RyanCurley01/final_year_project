# Environment variables for AI Recommendation Service
# Copy this file to .env and update the values according to your environment

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-game-music-store-bucket

# Backend API Configuration
# Dynamic URL that works for both local and Codespaces
# Will automatically use the correct URL based on environment
BACKEND_API_URL=${BACKEND_API_URL:-http://localhost:8080}

# Model Configuration
MODEL_PATH=./models/recommendation_model.onnx

# Service Configuration
SERVICE_PORT=5000
# Use 0.0.0.0 to allow connections from outside the container (works for both local and Codespaces)
SERVICE_HOST=0.0.0.0

# Database Configuration (if AI service needs direct DB access)
# Dynamic database URL that works for both local and Codespaces
DATABASE_URL=${DATABASE_URL:-mysql+pymysql://user:password@localhost:3306/game_music_store}

# Auto-detection variables (GitHub Codespaces sets these automatically)
# CODESPACE_NAME - automatically set in Codespaces
# GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN - automatically set in Codespaces

# YouTube API Configuration (replace with your actual API key)
YOUTUBE_API_KEY=AIzaSyA_cOSojH1AVc4phKoP14cYPkGUpdWhpuQ
YOUTUBE_CHANNEL_ID=@Ritrix252

# Environment Detection (automatically set by setup scripts)
ENVIRONMENT=local
