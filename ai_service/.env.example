# Environment variables for AI Recommendation Service

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-game-music-store-bucket

# Backend API Configuration
BACKEND_API_URL=http://localhost:8080

# Model Configuration
MODEL_PATH=./models/recommendation_model.onnx

# Service Configuration
SERVICE_PORT=5000
SERVICE_HOST=0.0.0.0

# Database Configuration (if AI service needs direct DB access)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/game_music_store
