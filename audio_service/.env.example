# Audio Service Environment Variables
# Copy this file to .env and replace the placeholder values

# Service Configuration
BACKEND_API_URL=http://localhost:8080
MODEL_PATH=./models/recommendation_model.onnx
SERVICE_PORT=5000
SERVICE_HOST=0.0.0.0
DATABASE_URL=mysql+pymysql://gamestore_user:your_password_here@host.docker.internal:3306/Game_Store_System
ENVIRONMENT=local

# Database Configuration
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=gamestore_user
MYSQL_PASSWORD=your_db_password_here
MYSQL_DATABASE=Game_Store_System

# Enable/disable external image pool generation/refill.
EXTERNAL_IMAGE_GENERATION_ENABLED=true

# Generated image pool storage cap (bytes). 2.2GB supports ~47 songs x 100 images
# with moderate headroom, depending on average hosted image size.
IMAGE_POOL_MAX_TOTAL_BYTES=2200000000
