# Backend Environment Variables
# 
# ⚠️  For Railway deployment, set these in the Railway dashboard:
#     Service > Variables
#
# Railway provides database credentials automatically if you add a MySQL plugin

# =============================================================================
# Database Configuration (Get from Railway MySQL plugin)
# =============================================================================
DB_HOST=${{MySQL.MYSQLHOST}}
DB_URL=jdbc:mysql://${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# =============================================================================
# AWS S3 Configuration (For file storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET_NAME=game-and-music-files

# =============================================================================
# PayPal Configuration (Get from PayPal Developer Dashboard)
# =============================================================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox  # Change to 'live' for production payments

# =============================================================================
# Frontend URL (For CORS - your Vercel deployment URL)
# =============================================================================
FRONTEND_BASE_URL=https://your-app.vercel.app

# Environment
ENVIRONMENT=production
