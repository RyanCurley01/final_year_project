# Frontend Environment Variables
# Variables prefixed with VITE_ are exposed to the browser

# YouTube Configuration
VITE_YOUTUBE_CHANNEL_ID=@Ritrix252

# API Configuration - Dynamic URLs that work in both local and Codespaces
# These will be automatically resolved by the environment detection script
VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://localhost:5000}
VITE_BACKEND_API_URL=${VITE_BACKEND_API_URL:-http://localhost:8080}

# Environment detection (automatically set by setup scripts)
VITE_ENVIRONMENT=${VITE_ENVIRONMENT:-local}

# Auto-detection variables (GitHub Codespaces sets these automatically)
# CODESPACE_NAME - automatically set in Codespaces
# GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN - automatically set in Codespaces

