# Frontend Environment Variables
# Variables prefixed with VITE_ are exposed to the browser and baked in at BUILD TIME
# 
# ⚠️  IMPORTANT: These values are PUBLIC - never put secrets here!
#
# For Vercel deployment, set these in the Vercel dashboard:
#   Project Settings > Environment Variables

# Environment type: local, codespaces, production
VITE_ENVIRONMENT=production

# =============================================================================
# API URLs - Set these to your Railway-deployed backend URLs
# =============================================================================
# Get these URLs from your Railway dashboard after deploying backend services
# Format: https://<service-name>.up.railway.app
# =============================================================================

# Audio/Songs Service (Python/FastAPI on Railway)
VITE_API_BASE_URL=https://your-audio-service.up.railway.app

# Accounts Service (Spring Boot on Railway)
VITE_BACKEND_API_URL=https://your-accounts-service.up.railway.app

# Products Service (Spring Boot on Railway)
VITE_PRODUCTS_API_URL=https://your-products-service.up.railway.app

# =============================================================================
# PayPal Configuration (Public Client ID only - secret stays on backend)
# =============================================================================
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Optional: Other services (uncomment and set if needed)
# VITE_ORDERS_API_URL=https://your-orders-service.up.railway.app
# VITE_PAYMENTS_API_URL=http://localhost:8083
# VITE_STOCK_API_URL=http://localhost:8084
# VITE_WISHLIST_API_URL=http://localhost:8085
# VITE_ORDER_ITEMS_API_URL=http://localhost:8086
# VITE_CUSTOMER_SUMMARY_API_URL=http://localhost:8087
# VITE_SOLD_PRODUCTS_API_URL=http://localhost:8088
# VITE_PURCHASED_PRODUCTS_API_URL=http://localhost:8089

