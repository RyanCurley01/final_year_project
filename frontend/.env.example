# Frontend Environment Variables Template
# Copy this file to .env and run setup_frontend_env.py or setup_frontend_env.sh
# Variables prefixed with VITE_ are exposed to the browser

# YouTube Configuration
VITE_YOUTUBE_CHANNEL_ID=@Ritrix252

# API Configuration - These will be automatically set by setup scripts
# Dynamic URLs that work in both local and Codespaces environments
VITE_API_BASE_URL=http://localhost:5000
VITE_BACKEND_API_URL=http://localhost:8080

# Environment detection - Automatically set by setup scripts
VITE_ENVIRONMENT=local

# Note: Run one of these commands to auto-configure for your environment:
# python setup_frontend_env.py
# ./setup_frontend_env.sh
