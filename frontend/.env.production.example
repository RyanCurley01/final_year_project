# Production Environment Variables
# Copy this file to .env.production and update with your actual production URLs
# These values are baked into the build at compile time

# YouTube Configuration

# Environment type
VITE_ENVIRONMENT=production

# =============================================================================
# IMPORTANT: Set these to your actual production API URLs!
# =============================================================================

# Audio/Songs Service
VITE_API_BASE_URL=https://your-audio-api.yourdomain.com

# Accounts Service
VITE_BACKEND_API_URL=https://your-backend-api.yourdomain.com

# Products Service  
VITE_PRODUCTS_API_URL=https://your-products-api.yourdomain.com

# Other services - uncomment and configure as needed
# VITE_ORDERS_API_URL=https://your-orders-api.yourdomain.com
# VITE_PAYMENTS_API_URL=https://your-payments-api.yourdomain.com
# VITE_STOCK_API_URL=https://your-stock-api.yourdomain.com
# VITE_WISHLIST_API_URL=https://your-wishlist-api.yourdomain.com
# VITE_ORDER_ITEMS_API_URL=https://your-order-items-api.yourdomain.com
# VITE_CUSTOMER_SUMMARY_API_URL=https://your-customer-summary-api.yourdomain.com
# VITE_SOLD_PRODUCTS_API_URL=https://your-sold-products-api.yourdomain.com
# VITE_PURCHASED_PRODUCTS_API_URL=https://your-purchased-products-api.yourdomain.com

# Pool video export allowlist (optional)
# Leave empty to disable the export controls for all users.
VITE_POOL_VIDEO_EXPORT_USER_EMAIL=
VITE_POOL_VIDEO_EXPORT_USER_FIREBASE_UID=
