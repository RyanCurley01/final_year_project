# Deployment Environment Variables
# Copy this file to .env and fill in secure values before deploying
# NEVER commit .env to version control

# ============================================
# DATABASE CREDENTIALS (REQUIRED)
# ============================================
# Generate secure passwords for production!
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_USER=gamestore_user
MYSQL_PASSWORD=your_secure_db_password_here

# ============================================
# AWS S3 CREDENTIALS (REQUIRED for file storage)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET_NAME=game-and-music-files

# ============================================
# PAYPAL CREDENTIALS (REQUIRED for payments)
# ============================================
# Get from https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox  # Change to 'live' for production payments
