{
  "name": "Game and Music Store Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "VARIANT": "ubuntu"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      },
      "extensions": [
    "vscjava.vscode-java-pack",
    "vscjava.vscode-gradle",
    "redhat.java",
    "ms-azuretools.vscode-docker",
    "ms-python.python",
    "esbenp.prettier-vscode",
    "ms-vscode.cpptools",
    "msjsdiag.debugger-for-chrome"
      ]
    }
  },
  "remoteUser": "vscode",
  "forwardPorts": [8080, 5173, 5000],
  "portsAttributes": {
    "8080": {
      "label": "Backend (Spring Boot)",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Frontend (React/Vite)",
      "onAutoForward": "notify"
    },
    "5000": {
      "label": "AI Service (FastAPI)",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "./.devcontainer/postCreate.sh || true",
  "features": {},
  "mounts": [
    "source=${localWorkspaceFolder}/Database Scripts,target=/workspace/database,type=bind,consistency=cached"
  ]
}
