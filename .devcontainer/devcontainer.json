{
  "name": "Game and Music Store Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/final_year_project",

  "userEnvProbe": "none",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        // Point Python extension to the venv created in the devcontainer
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.venvPath": "/opt"
      },
      "extensions": [
    "vscjava.vscode-java-pack",
    "vscjava.vscode-gradle",
    "ms-azuretools.vscode-docker",
    "ms-python.python",
    "esbenp.prettier-vscode",
    "ms-vscode.cpptools",
    "msjsdiag.debugger-for-chrome"
      ]
    }
  },

  "remoteUser": "root",

  "forwardPorts": [8080, 5173, 5000, 3306],

  "portsAttributes": {
    "8080": {
      "label": "Backend (Spring Boot)",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Frontend (React/Vite)",
      "onAutoForward": "notify"
    },
    "5000": {
      "label": "AI Service (FastAPI)",
      "onAutoForward": "notify"
    },
    "3306": {
      "label": "MySQL Database",
      "onAutoForward": "ignore"
    }
  },

  "postCreateCommand": "./.devcontainer/postCreate.sh || true",
  
  "features": {}
}
