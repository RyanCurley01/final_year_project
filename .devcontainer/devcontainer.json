{
  "name": "Game and Music Store Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "VARIANT": "ubuntu"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "maven.executable.path": "/usr/bin/mvn"
      },
      "extensions": [
    "vscjava.vscode-java-pack",
    "vscjava.vscode-maven",
    "redhat.java",
    "ms-azuretools.vscode-docker",
    "ms-python.python",
    "esbenp.prettier-vscode",
    "ms-vscode.cpptools",
    "msjsdiag.debugger-for-chrome"
      ]
    }
  },
  "remoteUser": "vscode",
  "forwardPorts": [8080, 3000, 5000, 5001],
  "postCreateCommand": "./.devcontainer/postCreate.sh || true",
  "features": {},
  "mounts": [
    "source=${localWorkspaceFolder}/Database Scripts,target=/workspace/database,type=bind,consistency=cached"
  ]
}
